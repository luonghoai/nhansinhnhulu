# ============ Shared ============
TEAM_TIMEZONE=Asia/Ho_Chi_Minh
DISCORD_BOT_TOKEN=          # ONE Discord bot token, shared by web (user fetch) + bot service
BOT_API_SECRET=            # shared secret for ALL web<->bot calls (both directions)

# ============ Web (Next.js / Vercel) ============
MONGODB_URI=               # Atlas free (M0) connection string — WEB ONLY (bot has no DB in Pattern B)
ADMIN_PASSWORD=            # plaintext admin password (simple-password auth)
SESSION_SECRET=            # signs the admin httpOnly session cookie
BOT_NOTIFY_URL=            # bot's notify server BASE url (web appends /notify), e.g. https://bot.example.com:8080
SITE_URL=                  # public landing page URL, included in raid announcements, e.g. https://nsnl.vercel.app

# ============ Bot (Python, on VPS) ============
# DISCORD_BOT_TOKEN=       # same token as above
GUILD_ID=                  # dev guild ID for instant slash-command sync
WEB_API_BASE_URL=          # where /api/bot/* lives, e.g. https://nsnl.vercel.app
# BOT_API_SECRET=          # same shared secret as web
BOT_NOTIFY_PORT=8080       # port the bot's /notify HTTP server listens on
RAID_ANNOUNCE_CHANNEL_ID=  # Discord text channel ID where new raids are announced (optional; unset = no announcement)
