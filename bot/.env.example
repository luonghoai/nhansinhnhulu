# Copy to .env for local development. See repo root ../.env.example for the
# full shared list. The bot has NO MongoDB access (Pattern B) — it talks only
# to the web app's /api/bot/* endpoints.

# ============ Shared ============
DISCORD_BOT_TOKEN=          # same token the web uses to fetch user name/avatar
BOT_API_SECRET=             # shared secret for ALL web<->bot calls (both directions)
TEAM_TIMEZONE=Asia/Ho_Chi_Minh

# ============ Bot ============
GUILD_ID=                   # dev guild ID for instant slash-command sync; unset = global sync
WEB_API_BASE_URL=           # where /api/bot/* lives, e.g. https://nsnl.vercel.app
BOT_NOTIFY_PORT=8080        # port the bot's /notify HTTP server listens on
